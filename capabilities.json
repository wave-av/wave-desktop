{
  "schemaVersion": "1",
  "repo": "wave-av/wave-desktop",
  "version": "0.3.0",
  "lifecycle": "alpha",
  "planeLayer": 0,
  "foundationPin": "v1",
  "maintainers": [{ "team": "operator" }],
  "exposes": {
    "renderSurfaces": [{ "kind": "electron-app", "id": "online.wave.desktop" }],
    "apis": [
      {
        "name": "control-plane",
        "protocol": "http",
        "address": "127.0.0.1:31415",
        "auth": "bearer",
        "endpoints": [
          { "method": "GET", "path": "/v1/status" },
          { "method": "GET", "path": "/v1/auth" },
          { "method": "POST", "path": "/v1/monitor/connect" },
          { "method": "POST", "path": "/v1/monitor/disconnect" }
        ],
        "binds": "loopback-only"
      }
    ]
  },
  "consumes": {
    "waveProducts": [
      { "repo": "wave-av/wave-gateway", "endpoint": "/oauth/device/code" },
      { "repo": "wave-av/wave-gateway", "endpoint": "/oauth/token" }
    ],
    "thirdParty": [
      { "service": "electron-safe-storage", "licenseGated": false }
    ],
    "foundationFrameworks": [
      "frameworks/protocol-plane",
      "frameworks/platform-registry",
      "frameworks/copywriting"
    ]
  },
  "events": {
    "publishes": [
      { "topic": "auth.signed-in", "transport": "sentry" },
      { "topic": "auth.sign-in.failed", "transport": "sentry" }
    ]
  },
  "tags": [
    "operator",
    "public",
    "electron",
    "on-prem",
    "build-on-wave",
    "oauth-device-code",
    "loopback-control-plane"
  ]
}
